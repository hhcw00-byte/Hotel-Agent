{
  "name": "hotel-ai-browser",
  "version": "1.0.0",
  "description": "酒店行业AI浏览器 - 基于Electron和Pi Coding Agent",
  "main": "dist/main/index.js",
  "scripts": {
    "build:database": "npx tsc -p database/tsconfig.json",
    "dev": "npm run build:database && webpack --mode development --watch",
    "build": "npm run build:database && webpack --mode production",
    "start": "node filter-stderr.js",
    "debug": "node scripts/dev-debug.js",
    "prebuild:sub": "node scripts/prebuild.js",
    "package": "npm run prebuild:sub && npm run build && electron-builder",
    "package:win": "npm run prebuild:sub && npm run build && electron-builder --win",
    "package:portable": "npm run prebuild:sub && npm run build && electron-builder --win portable",
    "package:dir": "npm run prebuild:sub && npm run build && electron-builder --dir",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist release"
  },
  "keywords": [
    "electron",
    "ai",
    "browser",
    "hotel",
    "pi-coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cron": "^2.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.1",
    "html-webpack-plugin": "^5.6.0",
    "javascript-obfuscator": "^5.4.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "chokidar": "^5.0.0",
    "cron": "^4.4.0",
    "electron-store": "^8.1.0",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.1",
    "marked": "^12.0.0",
    "mysql2": "^3.20.0",
    "openai": "^6.25.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.hotel.ai.browser",
    "productName": "Hotel-Agent",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/mysql2/**",
      "node_modules/sql.js/**",
      "dist/main/**"
    ],
    "extraResources": [
      {
        "from": "llm-config.json",
        "to": "llm-config.json"
      },
      {
        "from": "db-config.json",
        "to": "db-config.json"
      },
      {
        "from": "scripts/ai-web-crawler/dist",
        "to": "scripts/ai-web-crawler/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/ai-web-crawler/node_modules",
        "to": "scripts/ai-web-crawler/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/ai-web-crawler/config.enc",
        "to": "scripts/ai-web-crawler/config.enc"
      },
      {
        "from": "scripts/data-persistence",
        "to": "scripts/data-persistence",
        "filter": [
          "**/*.js"
        ]
      },
      {
        "from": "scripts/database-operations/dist",
        "to": "scripts/database-operations/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "tasks",
        "to": "tasks",
        "filter": [
          "**/*.json"
        ]
      },
      {
        "from": "database/dist",
        "to": "database/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "database/node_modules",
        "to": "database/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/api-runtime",
        "to": "scripts/api-runtime",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-ctrip-public-price",
        "to": "scripts/api-ctrip-public-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-trip-public-price",
        "to": "scripts/api-trip-public-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-ctrip-backend-price",
        "to": "scripts/api-ctrip-backend-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-meituan-backend-price",
        "to": "scripts/api-meituan-backend-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-booking-public-price",
        "to": "scripts/api-booking-public-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-booking-hotel-search",
        "to": "scripts/api-booking-hotel-search",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-booking-backend-price",
        "to": "scripts/api-booking-backend-price",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/login-check",
        "to": "scripts/login-check",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-meituan-realtime-status",
        "to": "scripts/api-meituan-realtime-status",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/data-cleaner",
        "to": "scripts/data-cleaner",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/data-store",
        "to": "scripts/data-store",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/api-ctrip-hotel-search",
        "to": "scripts/api-ctrip-hotel-search",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/file-operations",
        "to": "scripts/file-operations",
        "filter": ["**/*.js"]
      },
      {
        "from": "scripts/smart-price-adjust",
        "to": "scripts/smart-price-adjust",
        "filter": ["**/*.js", "!test-*.js", "!screenshots/**"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.business",
      "identity": null
    },
    "dmg": {
      "title": "Hotel-Agent ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
